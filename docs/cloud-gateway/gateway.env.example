# ==============================================================================
# 呈尚策划 美工生图系统 PRO · 云端网关环境变量模板
# 路径：/opt/csgh-gateway/secrets/gateway.env
# 权限：chown csgh:csgh && chmod 600（已由安装脚本设置）
# ==============================================================================

# --- 监听地址（Caddy 反代用，外部不直连，保持默认即可）-----------------------
BACKEND_GATEWAY_HOST=127.0.0.1
BACKEND_GATEWAY_PORT=8787

# --- Supabase（必填）---------------------------------------------------------
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://你的项目.supabase.co
VITE_SUPABASE_ANON_KEY=你的_anon_public_key
# Secret keys 区域 sb_secret_xxx，仅服务端使用
SUPABASE_SERVICE_ROLE_KEY=你的_service_role_key

# --- 5 条生图线路 API Key（按实际启用的线路填写）-----------------------------
# 线路 1（云雾 image-2）
IMAGE_2_API_KEY=
# 线路 2（云雾备用）
IMAGE_2_LINE2_API_KEY=
# 图片墙专用（可选）
NEW_PICTURE_WALL_IMAGE2_API_KEY=
# 线路 3（vectorengine）
VECTORENGINE_IMAGE_2_API_KEY=
# 线路 4（pockgo）
POCKGO_IMAGE_2_API_KEY=
IMAGE_2_LINE4_API_KEY=
# 线路 5（APIMart）
APIMART_IMAGE_2_API_KEY=
# 线路 6（manxiaobai，备用线路；网关内置 3 次自动重试）
MANXIAOBAI_IMAGE_2_API_KEY=

# --- 阿里云 OSS（必填）-------------------------------------------------------
# 推荐使用 RAM 子账号，仅授予 oss:PutObject + oss:GetObject 到指定 bucket
ALI_OSS_REGION=oss-cn-hangzhou
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_BUCKET=

# --- 品牌故事文案接口（仅启用 thread1 / yunwu）------------------------------
# 图片生成仍走上述 image-2 线路，无需额外密钥
BRAND_STORY_THREAD1_BASE_URL=https://yunwu.ai
BRAND_STORY_THREAD1_TEXT_API_KEY=
