{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "呈尚策划美工生图系统",
  "version": "0.1.0",
  "identifier": "com.csgh.image-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "呈尚策划 · 美工生图系统",
        "width": 1320,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 720,
        "decorations": true,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "外卖店招/头像 AI 一键生成",
    "longDescription": "基于 GPT-Image-2 的桌面应用，针对美团 / 淘宝闪购两大外卖平台批量生成店铺头像与店招宣传图。"
  },
  "plugins": {}
}
