{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认能力配置：允许主窗口使用对话框、文件系统写入、Shell 打开。",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-write",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "shell:allow-open"
  ]
}
